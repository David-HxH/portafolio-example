<section id="contact" class="py-24 px-6">
    <div class="max-w-4xl mx-auto">
        <div class="text-center mb-12">
            <h2 class="font-headline font-extrabold text-4xl md:text-5xl mb-4">
                {{{data.title}}}
            </h2>
            <p class="text-on-surface-variant text-lg mb-8 max-w-2xl mx-auto">
                {{data.subtitle}}
            </p>
        </div>

        <div class="max-w-2xl mx-auto">
            <form action="/contact" method="POST" class="space-y-6">
                <div class="grid md:grid-cols-2 gap-6">
                    <div>
                        <label for="name" class="block text-on-surface font-medium mb-2">Nombre *</label>
                        <input type="text" id="name" name="name" required
                               class="w-full px-4 py-3 bg-surface-container border border-outline-variant/30 rounded-lg text-on-surface placeholder-on-surface-variant/50 focus:outline-none focus:ring-2 focus:ring-primary focus:border-primary transition-all">
                    </div>
                    <div>
                        <label for="email" class="block text-on-surface font-medium mb-2">Email *</label>
                        <input type="email" id="email" name="email" required
                               class="w-full px-4 py-3 bg-surface-container border border-outline-variant/30 rounded-lg text-on-surface placeholder-on-surface-variant/50 focus:outline-none focus:ring-2 focus:ring-primary focus:border-primary transition-all">
                    </div>
                </div>

                <div>
                    <label for="subject" class="block text-on-surface font-medium mb-2">Asunto *</label>
                    <input type="text" id="subject" name="subject" required
                           class="w-full px-4 py-3 bg-surface-container border border-outline-variant/30 rounded-lg text-on-surface placeholder-on-surface-variant/50 focus:outline-none focus:ring-2 focus:ring-primary focus:border-primary transition-all">
                </div>

                <div>
                    <label for="message" class="block text-on-surface font-medium mb-2">Mensaje *</label>
                    <textarea id="message" name="message" rows="6" required
                              class="w-full px-4 py-3 bg-surface-container border border-outline-variant/30 rounded-lg text-on-surface placeholder-on-surface-variant/50 focus:outline-none focus:ring-2 focus:ring-primary focus:border-primary transition-all resize-vertical"
                              placeholder="Cuéntame sobre tu proyecto..."></textarea>
                </div>

                <div class="text-center">
                    <button type="submit" class="px-8 py-4 bg-gradient-to-br from-primary to-primary-container text-on-primary font-bold rounded-lg hover:shadow-[0_10px_30px_rgba(173,198,255,0.2)] transition-all active:scale-95 inline-flex items-center gap-2">
                        <span class="material-symbols-outlined">send</span>
                        Enviar Mensaje
                    </button>
                </div>
            </form>

            {{!-- <div class="text-center mt-8">
                <p class="text-on-surface-variant text-sm">
                    O si prefieres, puedes contactarme directamente en
                    <a href="mailto:{{data.email}}" class="text-primary hover:underline">{{data.email}}</a>
                </p>
            </div> --}}
        </div>
    </div>
</section>